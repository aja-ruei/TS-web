{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "_figma": {
    "$description": "Figma Variable 對照表，用於在其他 Figma 檔案重建同一套 Variables",
    "collections": {
      "Primitive": { "modes": ["Default"] },
      "Responsive": { "modes": ["Desktop", "Mobile"] },
      "Language": { "modes": ["tw", "en"] },
      "Semantic": { "modes": ["Default"] }
    }
  },

  "color": {
    "$description": "Primitive collection — 色票",
    "TS-red": {
      "100": { "$type": "color", "$value": "#f7ced1", "$description": "品牌紅 lightest" },
      "300": { "$type": "color", "$value": "#eb858b", "$description": "品牌紅 light" },
      "500": { "$type": "color", "$value": "#d70c18", "$description": "品牌紅 base" },
      "700": { "$type": "color", "$value": "#a10912", "$description": "品牌紅 dark" },
      "900": { "$type": "color", "$value": "#6c060c", "$description": "品牌紅 darkest" }
    },
    "RC-blue": {
      "100": { "$type": "color", "$value": "#e2fbfe", "$description": "Richart 藍 lightest" },
      "300": { "$type": "color", "$value": "#64cedb", "$description": "Richart 藍 light" },
      "500": { "$type": "color", "$value": "#17b6c9", "$description": "Richart 藍 base" },
      "700": { "$type": "color", "$value": "#15a6b7", "$description": "Richart 藍 dark" },
      "900": { "$type": "color", "$value": "#10818f", "$description": "Richart 藍 darkest" }
    },
    "neutral": {
      "50":  { "$type": "color", "$value": "#f3f5f6", "$description": "最淺灰" },
      "100": { "$type": "color", "$value": "#edf0f2", "$description": "頁面背景灰" },
      "200": { "$type": "color", "$value": "#dce0e5", "$description": "邊框灰" },
      "300": { "$type": "color", "$value": "#cdd3d9", "$description": "淺灰" },
      "400": { "$type": "color", "$value": "#b6bec7", "$description": "標籤文字灰" },
      "500": { "$type": "color", "$value": "#727d8c", "$description": "輔助文字灰" },
      "600": { "$type": "color", "$value": "#48556c", "$description": "內文灰" },
      "700": { "$type": "color", "$value": "#364053", "$description": "導航文字深灰" },
      "800": { "$type": "color", "$value": "#222935", "$description": "標題深灰" },
      "900": { "$type": "color", "$value": "#1b2028", "$description": "近黑" }
    },
    "white": { "$type": "color", "$value": "#fdfdfd", "$description": "純白" },
    "black": { "$type": "color", "$value": "#09090a", "$description": "近黑（標題用）" },
    "shadow": {
      "nav": { "$type": "color", "$value": "rgba(54, 64, 83, 0.08)", "$description": "導航陰影色" }
    }
  },

  "spacing": {
    "$description": "Primitive collection — 間距",
    "4":  { "$type": "dimension", "$value": "0.25rem", "$description": "4px" },
    "8":  { "$type": "dimension", "$value": "0.5rem", "$description": "8px" },
    "10": { "$type": "dimension", "$value": "0.625rem", "$description": "10px" },
    "12": { "$type": "dimension", "$value": "0.75rem", "$description": "12px" },
    "16": { "$type": "dimension", "$value": "1rem", "$description": "16px" },
    "20": { "$type": "dimension", "$value": "1.25rem", "$description": "20px" },
    "24": { "$type": "dimension", "$value": "1.5rem", "$description": "24px" },
    "80": { "$type": "dimension", "$value": "5rem", "$description": "80px" }
  },

  "responsive": {
    "$description": "Responsive collection — Desktop / Mobile 雙 mode",
    "fontSize": {
      "3xl": {
        "$type": "dimension",
        "$value": { "desktop": "2rem", "mobile": "1.5rem" },
        "$description": "32px / 24px"
      },
      "2xl": {
        "$type": "dimension",
        "$value": { "desktop": "1.5rem", "mobile": "1.25rem" },
        "$description": "24px / 20px"
      },
      "xl": {
        "$type": "dimension",
        "$value": { "desktop": "1.25rem", "mobile": "1.125rem" },
        "$description": "20px / 18px"
      },
      "lg": {
        "$type": "dimension",
        "$value": { "desktop": "1.125rem", "mobile": "1rem" },
        "$description": "18px / 16px"
      },
      "md": {
        "$type": "dimension",
        "$value": { "desktop": "1rem", "mobile": "0.875rem" },
        "$description": "16px / 14px"
      },
      "sm": {
        "$type": "dimension",
        "$value": { "desktop": "0.875rem", "mobile": "0.75rem" },
        "$description": "14px / 12px"
      },
      "xs": {
        "$type": "dimension",
        "$value": { "desktop": "0.75rem", "mobile": "0.625rem" },
        "$description": "12px / 10px"
      }
    },
    "fontWeight": {
      "regular": { "$type": "number", "$value": 400 },
      "medium":  { "$type": "number", "$value": 500 },
      "bold":    { "$type": "number", "$value": 700 }
    },
    "letterSpacing": {
      "wide":   {
        "$type": "dimension",
        "$value": { "desktop": "1px", "mobile": "0" },
        "$description": "導航用加寬字距"
      },
      "normal": {
        "$type": "dimension",
        "$value": { "desktop": "0", "mobile": "0" },
        "$description": "預設字距"
      }
    },
    "lineHeight": {
      "wide": {
        "$type": "number",
        "$value": 1.4,
        "$description": "寬行高。Figma 不支援綁定此值（會被解讀為 1.4px），Figma 中直接設定為 140% 或 Auto"
      },
      "normal": {
        "$type": "number",
        "$value": 1,
        "$description": "緊湊行高"
      }
    },
    "radius": {
      "btn": {
        "pill": {
          "$type": "dimension",
          "$value": "5rem",
          "$description": "80px — 膠囊按鈕，Desktop & Mobile 相同"
        }
      }
    },
    "layout": {
      "viewport": {
        "$type": "dimension",
        "$value": { "desktop": "1440px", "mobile": "375px" },
        "$description": "設計稿基準寬度"
      },
      "content": {
        "$type": "dimension",
        "$value": { "desktop": "1280px", "mobile": "351px" },
        "$description": "內容區最大寬度"
      }
    }
  },

  "language": {
    "$description": "Language collection — tw / en 雙 mode，切換語系字型",
    "font-family": {
      "$type": "fontFamily",
      "$value": { "tw": "Noto Sans TC", "en": "Montserrat" },
      "$description": "依語系切換主要字型"
    }
  },

  "semantic": {
    "$description": "Semantic collection — 語意別名，指向 Primitive",
    "surface": {
      "base":   { "$type": "color", "$value": "{color.neutral.100}", "$description": "頁面背景" },
      "header": { "$type": "color", "$value": "{color.neutral.50}", "$description": "Header 背景" },
      "footer": { "$type": "color", "$value": "{color.TS-red.500}", "$description": "Footer 背景" }
    },
    "text": {
      "heading":     { "$type": "color", "$value": "{color.black}", "$description": "標題" },
      "nav":         { "$type": "color", "$value": "{color.neutral.700}", "$description": "導航連結 — default" },
      "nav-hover":   { "$type": "color", "$value": "{color.TS-red.500}", "$description": "導航連結 — hover" },
      "nav-pressed": { "$type": "color", "$value": "{color.TS-red.700}", "$description": "導航連結 — pressed" },
      "content":     { "$type": "color", "$value": "{color.neutral.700}", "$description": "內文" },
      "caption":     { "$type": "color", "$value": "{color.neutral.500}", "$description": "問候語、輔助說明" },
      "label":       { "$type": "color", "$value": "{color.neutral.500}", "$description": "Mega Menu 分區小標" },
      "on-primary":  { "$type": "color", "$value": "{color.white}", "$description": "品牌色背景上的白字" }
    },
    "icon": {
      "default": { "$type": "color", "$value": "{color.neutral.700}", "$description": "預設圖示色" }
    },
    "btn": {
      "logout": { "$type": "color", "$value": "{color.TS-red.500}", "$description": "登出按鈕" }
    },
    "border": {
      "divider": { "$type": "color", "$value": "{color.neutral.200}", "$description": "分隔線" },
      "accent":  { "$type": "color", "$value": "{color.TS-red.500}", "$description": "品牌紅線裝飾 / Nav hover 底線" }
    }
  },

  "shadow": {
    "$description": "Effect Style（Figma 無法用 Variable 表達完整陰影，使用 Effect Style）",
    "nav": { "$type": "shadow", "$value": "0px 1px 4px rgba(54, 64, 83, 0.08)", "$description": "Mobile Header Nav" }
  }
}
